{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@google/model-viewer": "^4.1.0",
    "@splinetool/react-spline": "^4.0.0",
    "@splinetool/runtime": "^1.10.14",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.5.2",
    "react-scripts": "^5.0.1",
    "react-type-animation": "^3.2.0",
    "tailwindcss": "^4.2.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "concurrently \"npm run tailwind:watch\" \"react-scripts start\"",
    "build": "npm run tailwind:build && NODE_OPTIONS='--no-deprecation' react-scripts build",
    "tailwind:watch": "npx @tailwindcss/cli -i ./src/index.css -o ./src/output.css --watch",
    "tailwind:build": "npx @tailwindcss/cli -i ./src/index.css -o ./src/output.css",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
